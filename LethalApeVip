MainTab:CreateButton({
    Name = "Dịch chuyển tới Máy Scrap 🤖",
    Callback = function()
        local player = game.Players.LocalPlayer
        local character = player.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        
        if rootPart then
            SavedCFrame = rootPart.CFrame
            local foundMachine = false
            
            for _, obj in ipairs(workspace:GetDescendants()) do
                if (obj:IsA("BasePart") or obj:IsA("Model")) and string.find(string.lower(obj.Name), "scrap") then
                    local targetCFrame = obj:IsA("Model") and obj:GetPivot() or obj.CFrame
                    rootPart.CFrame = targetCFrame * CFrame.new(0, 4.5, 0)
                    foundMachine = true
                    break
                end
            end
            
            if not foundMachine then
                Rayfield:Notify({
                    Title = "Hệ thống",
                    Content = "Không tìm thấy Máy bán phế liệu nào trên bản đồ!",
                    Duration = 3,
                    Image = 4483362458,
                })
            end
        end
    end,
})

