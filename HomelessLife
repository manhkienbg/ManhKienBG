local OriginalMaterials = {}
local OriginalLighting = {
   GlobalShadows = game.Lighting.GlobalShadows,
   Resolution = settings().Rendering.QualityLevel
}

local function ApplyAntiLag()
   for _, obj in pairs(workspace:GetDescendants()) do
      if obj:IsA("BasePart") and not obj:IsA("Terrain") then
         if not OriginalMaterials[obj] then
            OriginalMaterials[obj] = {Material = obj.Material, Reflectance = obj.Reflectance}
         end
         obj.Material = Enum.Material.SmoothPlastic
         obj.Reflectance = 0
      elseif obj:IsA("Decal") or obj:IsA("Texture") then
         if not OriginalMaterials[obj] then
            OriginalMaterials[obj] = {Transparency = obj.Transparency}
         end
         obj.Transparency = 1
      end
   end
   
   if workspace:FindFirstChildOfClass("Terrain") then
      local terrain = workspace:FindFirstChildOfClass("Terrain")
      if not OriginalMaterials[terrain] then
         OriginalMaterials[terrain] = {Decoration = terrain.Decoration}
      end
      terrain.Decoration = false
   end
   
   game.Lighting.GlobalShadows = false
   for _, effect in pairs(game.Lighting:GetDescendants()) do
      if effect:IsA("PostEffect") or effect:IsA("BloomEffect") or effect:IsA("BlurEffect") or effect:IsA("SunRaysEffect") or effect:IsA("ColorCorrectionEffect") then
         if not OriginalMaterials[effect] then
            OriginalMaterials[effect] = {Enabled = effect.Enabled}
         end
         effect.Enabled = false
      end
   end
end

local function RestoreGraphics()
   for obj, properties in pairs(OriginalMaterials) do
      if obj and obj.Parent then
         pcall(function()
            for prop, value in pairs(properties) do
               obj[prop] = value
            end
         end)
      end
   end
   OriginalMaterials = {}
   game.Lighting.GlobalShadows = OriginalLighting.GlobalShadows
end

workspace.DescendantAdded:Connect(function(obj)
   if Rayfield.Flags.AntiLagToggle and Rayfield.Flags.AntiLagToggle.CurrentValue then
      task.wait()
      pcall(function()
         if obj:IsA("BasePart") and not obj:IsA("Terrain") then
            if not OriginalMaterials[obj] then OriginalMaterials[obj] = {Material = obj.Material, Reflectance = obj.Reflectance} end
            obj.Material = Enum.Material.SmoothPlastic
            obj.Reflectance = 0
         elseif obj:IsA("Decal") or obj:IsA("Texture") then
            if not OriginalMaterials[obj] then OriginalMaterials[obj] = {Transparency = obj.Transparency} end
            obj.Transparency = 1
         end
      end)
   end
end)

